# EDGE — Research Driven Development: single configuration file.
#
# Copy to template.env, fill it in, then run ./install.sh.
# install.sh uses it twice:
#   1. render-time — every RDD_FOO=bar becomes the {{FOO}} token in the
#      markdown/json5 templates (agent prompts, charter, topic binding).
#   2. runtime — the file is installed to ~/.config/edge-rdd/config.env,
#      where scripts/edge-coder-run.sh sources it on every dispatch.
#
# Values must be plain KEY=value lines (this file is sourced by bash AND
# parsed by the renderer — no command substitution, no multiline values).

# ---- identity ---------------------------------------------------------------
# The research agent's OpenClaw id and display name.
RDD_AGENT_ID=edge
RDD_AGENT_NAME=EDGE
# Operating philosophy seeded into the workspace SOUL.md on first install
# (FRONTIER | AGAINST | INFINITY | BAYESIAN — see workspace-edge/personas/).
RDD_PERSONA=FRONTIER
# Absolute home dir of the user running OpenClaw + opencode (no trailing slash).
RDD_HOME=/home/youruser

# ---- project ------------------------------------------------------------------
RDD_PROJECT_NAME=MyProject
RDD_PROJECT_SLUG=myproject
# GitHub repo the coder team owns (OWNER/NAME) and its URL.
RDD_REPO_SLUG=youruser/yourrepo
RDD_REPO_URL=https://github.com/youruser/yourrepo
# Local clone the coders work in (must be a git repo root).
RDD_REPO_DIR=/home/youruser/projects/yourrepo
# Protected trunk branch PRs merge into, and the feature-branch prefix.
RDD_MAIN_BRANCH=main
RDD_BRANCH_PREFIX=cm
# Directory INSIDE the project repo holding the agent handoff docs
# (PROJECT_STATE.md, TASKS.md, RESEARCH_TRANSFER.md, EDGE_COLLABORATION.md, ...).
RDD_DOCS_DIR=docs/agent

# ---- chat surface (Telegram via OpenClaw) --------------------------------------
# Numeric Telegram user id of the human operator (for elevated exec allowlist).
RDD_OPERATOR_TG_USER_ID=123456789
# Group chat id and forum-topic id of the project thread EDGE lives in.
# Leave RDD_TG_TARGET empty to disable chat pushes (wrapper logs instead).
RDD_TG_CHANNEL=telegram
RDD_TG_TARGET=-1001234567890
RDD_TG_THREAD=1234

# ---- models --------------------------------------------------------------------
# Coder tier ladder, best-first, space separated. opencode has NO native
# retry/fallback — this ordered list IS the fallback layer. Give flaky/cheap
# models a short timeout and put them last.
RDD_MODELS="openai/gpt-5.5 deepseek/deepseek-v4-pro"
# Per-tier hard timeouts (seconds), index-aligned with RDD_MODELS.
# BG = async dispatch (generous). FG = foreground; the SUM must stay inside the
# dispatching agent's exec-timeout budget (OpenClaw default 3600s).
RDD_TIMEOUTS_BG="3600 2400"
RDD_TIMEOUTS_FG="1800 1500"
# Model tier 1 is also baked into the coder agent frontmatter at render time.
RDD_MODEL_CODER_T1=openai/gpt-5.5
# Research agent (EDGE) primary model — used in the openclaw agent snippet.
RDD_EDGE_MODEL_PRIMARY=zai/glm-5.2

# ---- binaries / paths -----------------------------------------------------------
RDD_OPENCODE=/home/youruser/.opencode/bin/opencode
RDD_OPENCLAW=/home/youruser/.local/bin/openclaw
# Prepended to PATH inside the wrapper — make sure gh, flock, setsid, jq are
# reachable when the gateway (systemd) spawns the dispatch with a minimal PATH.
RDD_PATH_PREPEND=/home/youruser/.local/bin:/home/linuxbrew/.linuxbrew/bin
# opencode agent to dispatch.
RDD_AGENT=code-monkeys/coder

# ---- wrapper state ---------------------------------------------------------------
RDD_LOG=/home/youruser/.local/state/edge-rdd/edge-coder-run.log
RDD_RUNS_DIR=/home/youruser/.local/state/edge-rdd/runs
RDD_LOCKDIR=/home/youruser/.local/state/edge-rdd/locks

# ---- CI watcher --------------------------------------------------------------------
# Poll interval (s) and max polls after a PR opens (60 x 40 = ~40 min window).
RDD_CI_POLL_SECS=60
RDD_CI_POLL_MAX=40

# ---- PR gate (scripts/edge-pr-gate.sh) -----------------------------------------------
# On-demand sweep (`/gate sweep` in chat) that posts merge / branch-cleanup
# approval buttons to the gate thread, and executes them ONLY after the operator
# taps (goal: every repo stays trunk-only).
# Projects = every *.env in RDD_GATE_CONFIG_DIR that defines RDD_REPO_DIR —
# the same files the dispatch wrapper reads, so there is no second registry.
#RDD_GATE_CONFIG_DIR=/home/youruser/.config/edge-rdd
#RDD_GATE_STATE_DIR=/home/youruser/.local/state/edge-rdd/pr-gate
# THE ONE GATE THREAD. Every project's approval asks AND action confirmations
# post here, so you approve everything from one place instead of chasing
# per-project threads (recommended: your EDGE home/coordination thread). Each
# ask carries a plain-language what-it-does / consequence / why brief per action.
# install.sh writes these to ~/.config/edge-rdd/gate.env. Leave them equal to
# your single project's RDD_TG_* below if you run only one project — the gate
# then simply posts into that one thread.
RDD_GATE_TG_CHANNEL=telegram
RDD_GATE_TG_TARGET=-1001234567890
RDD_GATE_TG_THREAD=1234
# Merge strategy for approved PRs: squash | merge | rebase (branch is always deleted).
#RDD_GATE_MERGE_METHOD=squash
# Re-post an unchanged approval ask after this many hours (snooze uses it too).
#RDD_GATE_REASK_HOURS=24
# Max inline buttons per project message; overflow is listed as text.
#RDD_GATE_MAX_BUTTONS=6
# Required CI check contexts on the protected trunk, comma-separated.
# Must EXACTLY match the CI job names GitHub reports (see github/protect-branch.sh).
RDD_REQUIRED_CHECKS="tests, lint"
