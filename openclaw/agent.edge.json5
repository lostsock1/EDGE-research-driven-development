// EDGE research agent — merge this object into agents.list[] in ~/.openclaw/openclaw.json
// (JSON5: comments + trailing commas allowed). Restart the gateway afterwards:
//   systemctl --user restart openclaw-gateway
{
  id: "{{AGENT_ID}}",
  name: "{{AGENT_NAME}}",
  workspace: "{{HOME}}/.openclaw/workspace-{{AGENT_ID}}",

  // Make the agent's OWN notes searchable via memory_search — without this the
  // agent only sees the default memory index and is blind to its research notes.
  memorySearch: {
    extraPaths: [
      "{{HOME}}/.openclaw/workspace-{{AGENT_ID}}/notes",
      "{{HOME}}/.openclaw/workspace-{{AGENT_ID}}/projects",
    ],
  },

  model: {
    primary: "{{EDGE_MODEL_PRIMARY}}",
    // Order matters. WARNING: a user-pinned session model (/model in chat)
    // silently disables this ENTIRE fallback chain — a 429 then surfaces as a
    // hard error. Clear stale pins from the agent's sessions.json if a model
    // "mysteriously" stops failing over.
    fallbacks: [
      "deepseek/deepseek-v4-pro",
    ],
  },

  // "gate" registers the /gate slash command (the PR-gate skill in
  // openclaw/skills/gate/); keep it here or the agent can't invoke it, since a
  // per-agent skills[] list is an allowlist that replaces the defaults.
  skills: ["github", "gh-issues", "gate"],
  sandbox: { mode: "off" },

  // Heartbeat — kept for future use; currently has no active tasks (the PR
  // gate sweep runs on-demand via `/gate sweep`, not via heartbeat).
  // WARNING: the moment ANY agent defines a heartbeat block, agents WITHOUT one
  // stop running heartbeats. If other agents on this gateway rely on default
  // heartbeats, give each an explicit block too — `heartbeat: { every: "30m" }`
  // preserves the default behavior exactly.
  heartbeat: {
    every: "30m",
    target: "telegram",
    // Heartbeat alerts (the sweep's cross-project summary) land here. The PR
    // gate's own approval-button messages post to the single gate thread set in
    // ~/.config/edge-rdd/gate.env (RDD_GATE_TG_*) — point both at your EDGE
    // coordination thread so everything gate-related arrives in one place.
    to: "{{TG_TARGET}}:topic:{{TG_THREAD}}",
  },

  tools: {
    profile: "coding",
    alsoAllow: ["message", "group:messaging"],
    // Elevated exec (needed to run the dispatch wrapper) ONLY for the human
    // operator's own account — never open this to a whole group.
    elevated: {
      enabled: true,
      allowFrom: { telegram: ["{{OPERATOR_TG_USER_ID}}"] },
    },
    fs: { workspaceOnly: true },
  },

  identity: {
    name: "{{AGENT_NAME}}",
    theme: "truth-seeking research operator",
    emoji: "⚡",
  },
}
