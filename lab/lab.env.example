# EDGE Gapped Lab — configuration
# Source this file before using lab-run.sh, or export vars directly.
#
# Copy to lab.env.local and edit for your setup.

# Docker image tag
LAB_IMAGE=edge-gapped-lab:latest

# Container resource limits
LAB_MEMORY=2g
LAB_CPUS=2
LAB_TIMEOUT=600

# Network isolation (none = fully air-gapped, bridge = internet access)
LAB_NETWORK=none

# Paths (auto-detected, override only if needed)
# LAB_WORKSPACE=<workspace-edge root>
# LAB_EXPERIMENTS_DIR=<where experiment directories live>
